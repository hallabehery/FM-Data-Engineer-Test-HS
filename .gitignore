# --- Internal hiring material — never distribute to candidates ---
_internal/

# --- DuckDB warehouse ---
# The populated submission/warehouse.duckdb IS committed — SETUP.md §8 asks for the populated
# warehouse to be handed back (committed or zipped). It's a build output (`make pipeline`),
# never hand-edited. Every other .duckdb stays ignored (e.g. a stray root-level warehouse
# from running the SETUP examples), as do write-ahead logs.
*.duckdb
*.duckdb.wal
!submission/warehouse.duckdb

# Note: submission/star_map.html IS also committed — a small (~700 KB), self-contained
# illustrative deliverable a reviewer can open straight from the repo (regenerate with
# `make render`).

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- Jupyter ---
.ipynb_checkpoints/
.jupyter/
*.ipynb_checkpoints

# --- Local tooling noise (agent sessions, pytest cache) ---
.claude/
.pytest_cache/

